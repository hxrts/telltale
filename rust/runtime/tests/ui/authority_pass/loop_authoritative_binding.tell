effect Runtime
  authoritative ready : Session -> Result ReadyErr ReadyWitness
  {
    class : authoritative
    progress : may_block
    region : fragment
    agreement_use : required
    reentrancy : reject_same_fragment
  }

type ReadyErr =
  | NotReady

type alias ReadyWitness =
{
  epoch : Int
}

protocol LoopAuthoritativeBinding uses Runtime =
  roles Coordinator, Worker
  authoritative let readiness = check Runtime.ready(session)
  loop repeat 2
    Coordinator -> Worker : Tick(readiness)
