use telltale_vm::coroutine::Value;
use telltale_vm::effect::{
    EffectHandler, EffectOutcome, EffectRequest, EffectRequestBody, EffectResponse, SendDecision,
    TopologyPerturbation,
};
use telltale_vm::OutputConditionHint;

/// Deterministic host integration scaffold.
pub struct {{STRUCT_NAME}};

impl EffectHandler for {{STRUCT_NAME}} {
    fn handler_identity(&self) -> String {
        "{{STRUCT_NAME}}".to_string()
    }

    fn handle_effect(&self, request: EffectRequest) -> EffectOutcome {
        match request.body {
            EffectRequestBody::SendDecision { payload, .. } => {
                let payload = payload.unwrap_or(Value::Unit);
                EffectOutcome::success(EffectResponse::SendDecision {
                    decision: SendDecision::Deliver(payload),
                })
            }
            EffectRequestBody::Receive { state, .. } => {
                EffectOutcome::success(EffectResponse::Receive { state })
            }
            EffectRequestBody::Choose { labels, .. } => {
                let label = labels
                    .first()
                    .cloned()
                    .unwrap_or_else(|| "default".to_string());
                EffectOutcome::success(EffectResponse::Choose { label })
            }
            EffectRequestBody::InvokeStep { state, .. } => {
                EffectOutcome::success(EffectResponse::InvokeStep { state })
            }
            EffectRequestBody::Acquire { .. } => {
                EffectOutcome::success(EffectResponse::Acquire {
                    evidence: Value::Unit,
                })
            }
            EffectRequestBody::Release { .. } => EffectOutcome::success(EffectResponse::Release),
            EffectRequestBody::TopologyEvents { .. } => {
                EffectOutcome::success(EffectResponse::TopologyEvents {
                    events: Vec::<TopologyPerturbation>::new(),
                })
            }
            EffectRequestBody::OutputConditionHint { .. } => {
                EffectOutcome::success(EffectResponse::OutputConditionHint {
                    hint: Some(OutputConditionHint {
                        predicate_ref: format!("{}.authoritative_output", self.handler_identity()),
                        witness_ref: Some("scaffold/default".to_string()),
                    }),
                })
            }
        }
    }
}

// Integration checklist:
// - [ ] Keep all request/outcome handling deterministic for equal inputs.
// - [ ] Keep handler_identity stable for the full runtime lifetime.
// - [ ] Do not mutate shared host state outside explicit request handling boundaries.
// - [ ] Validate host assumptions for topology ordering, session ownership, and effect metadata.
// - [ ] Do not promote observed host snapshots into semantic truth; return authoritative
//       `OutputConditionHint` / acquire evidence for parity-critical success paths.
// - [ ] Require canonical handles or ownership receipts on later parity-critical host paths.
